{
  "Version": "2019-10-30",
  "Type": "contactFlow",
  "Name": "PolicyAssistantChatFlow",
  "StartAction": "11111111-1111-1111-1111-111111111001",
  "Metadata": {
    "entryPointPosition": { "x": 20, "y": 20 },
    "ActionMetadata": {
      "11111111-1111-1111-1111-111111111001": { "position": { "x": 20,   "y": 20  } },
      "11111111-1111-1111-1111-111111111002": { "position": { "x": 250,  "y": 20  } },
      "11111111-1111-1111-1111-111111111003": { "position": { "x": 500,  "y": 20  } },
      "11111111-1111-1111-1111-111111111004": { "position": { "x": 750,  "y": 20  } },
      "11111111-1111-1111-1111-111111111005": { "position": { "x": 1000, "y": 20  } },
      "11111111-1111-1111-1111-111111111006": { "position": { "x": 1250, "y": 20  } }
    }
  },
  "Actions": [
    {
      "Identifier": "11111111-1111-1111-1111-111111111001",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "Welcome! I am your AI Policy Assistant. How can I help you today?"
      },
      "Transitions": {
        "NextAction": "11111111-1111-1111-1111-111111111002",
        "Errors": [],
        "Conditions": []
      }
    },
    {
      "Identifier": "11111111-1111-1111-1111-111111111002",
      "Type": "GetParticipantInput",
      "Parameters": {
        "Text": "Please provide your policy number.",
        "Timeout": "120",
        "LexV2Bot": {
          "AliasArn": "arn:aws:lex:<region>:<account_id>:bot-alias/<bot_id>/<alias_id>"
        }
      },
      "Transitions": {
        "NextAction": "11111111-1111-1111-1111-111111111003",
        "Errors": [
          { "NextAction": "11111111-1111-1111-1111-111111111005", "ErrorType": "NoMatchingError" },
          { "NextAction": "11111111-1111-1111-1111-111111111005", "ErrorType": "TimedOut" }
        ],
        "Conditions": [
          {
            "NextAction": "11111111-1111-1111-1111-111111111003",
            "Condition": {
              "Operator": "Equals",
              "Operands": ["$.Lex.IntentName", "CapturePolicyNumber"]
            }
          }
        ]
      }
    },
    {
      "Identifier": "11111111-1111-1111-1111-111111111003",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "arn:aws:lambda:<region>:<account_id>:function:policy_handler",
        "InvocationTimeLimitSeconds": "8",
        "LambdaInvocationAttributes": {
          "policyNumber": "$.Lex.SessionAttributes.policyNumber",
          "policyStatus": "$.Lex.SessionAttributes.policyStatus"
        }
      },
      "Transitions": {
        "NextAction": "11111111-1111-1111-1111-111111111004",
        "Errors": [
          { "NextAction": "11111111-1111-1111-1111-111111111005", "ErrorType": "NoMatchingError" },
          { "NextAction": "11111111-1111-1111-1111-111111111005", "ErrorType": "TimedOut" }
        ],
        "Conditions": []
      }
    },
    {
      "Identifier": "11111111-1111-1111-1111-111111111004",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "Thank you! Your policy has been found and is being processed."
      },
      "Transitions": {
        "NextAction": "11111111-1111-1111-1111-111111111006",
        "Errors": [],
        "Conditions": []
      }
    },
    {
      "Identifier": "11111111-1111-1111-1111-111111111005",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "I'm sorry, I could not process your request. Please try again or contact support."
      },
      "Transitions": {
        "NextAction": "11111111-1111-1111-1111-111111111006",
        "Errors": [],
        "Conditions": []
      }
    },
    {
      "Identifier": "11111111-1111-1111-1111-111111111006",
      "Type": "DisconnectParticipant",
      "Parameters": {},
      "Transitions": {}
    }
  ]
}
