{
  "Version": "2019-10-30",
  "StartAction": "welcome-message",
  "Metadata": {
    "entryPointPosition": { "x": 20, "y": 20 },
    "ActionMetadata": {
      "welcome-message":    { "position": { "x": 20,   "y": 20  } },
      "ai-agent-block":     { "position": { "x": 250,  "y": 20  } },
      "set-policy-number":  { "position": { "x": 500,  "y": 20  } },
      "invoke-lambda":      { "position": { "x": 750,  "y": 20  } },
      "success-response":   { "position": { "x": 1000, "y": 20  } },
      "error-response":     { "position": { "x": 1000, "y": 150 } },
      "disconnect":         { "position": { "x": 1250, "y": 20  } }
    }
  },
  "Actions": [
    {
      "Identifier": "welcome-message",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "Welcome! I am your AI Policy Assistant powered by Amazon Connect AI Agent. How can I help you today?"
      },
      "Transitions": {
        "NextAction": "ai-agent-block"
      }
    },
    {
      "Identifier": "ai-agent-block",
      "Type": "GetParticipantInput",
      "Parameters": {
        "Text": "Please tell me your policy number and I will look it up for you.",
        "AIAgent": {
          "Type": "SELF_SERVICE",
          "SelfServiceAIAgentId": "<connect_ai_agent_id>"
        },
      },
      "Transitions": {
        "NextAction": "set-policy-number",
        "Conditions": [
          {
            "NextAction": "set-policy-number",
            "Condition": {
              "Operator": "Equals",
              "Operands": ["$.Lex.IntentName", "CapturePolicyNumber"]
            }
          },
          {
            "NextAction": "error-response",
            "Condition": {
              "Operator": "Equals",
              "Operands": ["$.Lex.IntentName", "FallbackIntent"]
            }
          }
        ],
        "Errors": [
          { "NextAction": "error-response", "ErrorType": "NoMatchingError" },
          { "NextAction": "error-response", "ErrorType": "TimedOut" }
        ]
      }
    },
    {
      "Identifier": "set-policy-number",
      "Type": "UpdateContactAttributes",
      "Parameters": {
        "Attributes": {
          "policyNumber": "$.Lex.Slots.policyNumber"
        }
      },
      "Transitions": {
        "NextAction": "invoke-lambda"
      }
    },
    {
      "Identifier": "invoke-lambda",
      "Type": "InvokeLambdaFunction",
      "Parameters": {
        "LambdaFunctionARN": "arn:aws:lambda:<region>:<account_id>:function:policy_handler",
        "InvocationTimeLimitSeconds": "8",
        "LambdaInvocationAttributes": {
          "policyNumber": "$.Attributes.policyNumber"
        }
      },
      "Transitions": {
        "NextAction": "success-response",
        "Errors": [
          { "NextAction": "error-response", "ErrorType": "NoMatchingError" },
          { "NextAction": "error-response", "ErrorType": "TimedOut" }
        ]
      }
    },
    {
      "Identifier": "success-response",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "Thank you! Your policy has been found and is being processed. Our team will assist you shortly."
      },
      "Transitions": {
        "NextAction": "disconnect"
      }
    },
    {
      "Identifier": "error-response",
      "Type": "MessageParticipant",
      "Parameters": {
        "Text": "I'm sorry, I could not process your request. Please try again or contact support."
      },
      "Transitions": {
        "NextAction": "disconnect"
      }
    },
    {
      "Identifier": "disconnect",
      "Type": "DisconnectParticipant",
      "Parameters": {}
    }
  ]
}
